    int n , i, flag= 1;
   printf("enter the number");
   scanf("%d" ,&n);
   if (n<=1){
    flag = 0;

   }
   else{
    for (i =2; i < n; i++){
       if ( n % i == 0 ) {
        flag = 0; 
