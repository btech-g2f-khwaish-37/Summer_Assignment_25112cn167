\\Program to calculate the sum of first N natural numbers.
#include<studio.h>
int main()
{
int n,i,sum=0;
printf("Enter a positive number");
scanf("%d",&n);
for(i=1; i<=n; ++i)
{
 sum+= i;
}
printf("Sum of first n natural number");
scanf("%d\n", n , sum);
 return 0; 
}


