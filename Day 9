//Program to print repeated character pattern
A
BB
CCC
DDDD
EEEEE
#include <stdio.h>
int main() {
    char ch = 'A';
    for ( int i = 1; i <= 5; i++) {
        for ( int j = 1; j <= i; j++) {
            printf("%c", ch);
        }
        printf("\n");
        ch++;
    }
    return 0;
}



//Program to print hollow square pattern 
