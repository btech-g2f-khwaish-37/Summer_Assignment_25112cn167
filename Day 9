//Program to print reverse star pattern
*****
****
***
**
*
#include <stdio.h>
int main()
{
    for(int i = 5;i >= 1; --i){
        for(int j =1; j <=i; ++j){   
                printf("*");            
        }
        printf("\n");
    }
    return 0;
}


