// Program to Create Salary Management System.

#include <stdio.h>

#define MAX_EMPLOYEES 100

struct Salary {
    int id;
    char name[50];
    float basicSalary;
    float hra;
    float da;
    float grossSalary;
};

int main() {
    struct Salary emp[MAX_EMPLOYEES];
    int choice, count = 0;

    while (1) {

        printf("\n===== Salary Management System =====\n");
        printf("1. Add Employee Salary\n");
        printf("2. Display All Salary Records\n");
        printf("3. Exit\n");
        printf("Enter your choice: ");

        if (scanf("%d", &choice) != 1) {
            printf("Invalid input! Please enter a number.\n");
            while (getchar() != '\n');
            continue;
        }

        switch (choice) {

            case 1:

                if (count >= MAX_EMPLOYEES) {
                    printf("Database is full!\n");
                    break;
                }

                while (1) {
                    printf("Enter Employee ID: ");

                    if (scanf("%d", &emp[count].id) != 1) {
                        printf("Invalid Employee ID! Please enter an integer.\n");
                        while (getchar() != '\n');
                        continue;
                    }

                    int duplicate = 0;

                    for (int i = 0; i < count; i++) {
                        if (emp[i].id == emp[count].id) {
                            duplicate = 1;
                            break;
                        }
                    }

                    if (duplicate) {
                        printf("Employee ID already exists! Enter another ID.\n");
                        continue;
                    }

                    break;
                }

                printf("Enter Employee Name: ");
                scanf(" %49[^\n]", emp[count].name);

                while (1) {
                    printf("Enter Basic Salary: ");

                    if (scanf("%f", &emp[count].basicSalary) != 1) {
                        printf("Invalid input! Please enter a number.\n");
                        while (getchar() != '\n');
                        continue;
                    }

                    if (emp[count].basicSalary < 0) {
                        printf("Salary cannot be negative.\n");
                        continue;
                    }

                    break;
                }

                emp[count].hra = emp[count].basicSalary * 0.20;
                emp[count].da = emp[count].basicSalary * 0.10;
                emp[count].grossSalary = emp[count].basicSalary + emp[count].hra + emp[count].da;

                count++;

                printf("Salary record added successfully.\n");
                break;

            case 2:

                if (count == 0) {
                    printf("No salary records found.\n");
                } else {

                    printf("\n=============== Salary Records ===============\n");

                    for (int i = 0; i < count; i++) {

                        printf("\nEmployee %d\n", i + 1);
                        printf("Employee ID  : %d\n", emp[i].id);
                        printf("Name         : %s\n", emp[i].name);
                        printf("Basic Salary : %.2f\n", emp[i].basicSalary);
                        printf("HRA (20%%)    : %.2f\n", emp[i].hra);
                        printf("DA (10%%)     : %.2f\n", emp[i].da);
                        printf("Gross Salary : %.2f\n", emp[i].grossSalary);
                        printf("----------------------------------------------\n");
                    }
                }

                break;

            case 3:
                printf("Thank you for using the Salary Management System.\n");
                return 0;

            default:
                printf("Invalid choice! Please enter 1, 2 or 3.\n");
        }
    }

    return 0;
}



// Program to Create Marksheet Generation System.

#include <stdio.h>

#define MAX_STUDENTS 100
#define SUBJECTS 5

struct Student {
    int rollNo;
    char name[50];
    float marks[SUBJECTS];
    float total;
    float percentage;
    char grade;
};

int main() {
    struct Student s[MAX_STUDENTS];
    int choice, count = 0;

    while (1) {

        printf("\n===== Marksheet Generation System =====\n");
        printf("1. Add Student Marksheet\n");
        printf("2. Display All Marksheets\n");
        printf("3. Exit\n");
        printf("Enter your choice: ");

        if (scanf("%d", &choice) != 1) {
            printf("Invalid input! Please enter a number.\n");
            while (getchar() != '\n');
            continue;
        }

        switch (choice) {

            case 1:

                if (count >= MAX_STUDENTS) {
                    printf("Database is full!\n");
                    break;
                }

                printf("Enter Roll Number: ");
                scanf("%d", &s[count].rollNo);

                printf("Enter Student Name: ");
                scanf(" %49[^\n]", s[count].name);

                s[count].total = 0;

                printf("Enter marks for 5 subjects:\n");

                for (int i = 0; i < SUBJECTS; i++) {

                    while (1) {
                        printf("Subject %d: ", i + 1);

                        if (scanf("%f", &s[count].marks[i]) != 1) {
                            printf("Invalid input! Please enter a number.\n");
                            while (getchar() != '\n');
                            continue;
                        }

                        if (s[count].marks[i] < 0 || s[count].marks[i] > 100) {
                            printf("Marks should be between 0 and 100.\n");
                            continue;
                        }

                        break;
                    }

                    s[count].total += s[count].marks[i];
                }

                s[count].percentage = s[count].total / SUBJECTS;

                if (s[count].percentage >= 90)
                    s[count].grade = 'A';
                else if (s[count].percentage >= 75)
                    s[count].grade = 'B';
                else if (s[count].percentage >= 60)
                    s[count].grade = 'C';
                else if (s[count].percentage >= 40)
                    s[count].grade = 'D';
                else
                    s[count].grade = 'F';

                count++;

                printf("Marksheet generated successfully.\n");
                break;

            case 2:

                if (count == 0) {
                    printf("No marksheets available.\n");
                } else {

                    printf("\n========== All Marksheets ==========\n");

                    for (int i = 0; i < count; i++) {

                        printf("\nStudent %d\n", i + 1);
                        printf("Roll Number : %d\n", s[i].rollNo);
                        printf("Name        : %s\n", s[i].name);

                        for (int j = 0; j < SUBJECTS; j++) {
                            printf("Subject %d   : %.2f\n", j + 1, s[i].marks[j]);
                        }

                        printf("Total       : %.2f\n", s[i].total);
                        printf("Percentage  : %.2f%%\n", s[i].percentage);
                        printf("Grade       : %c\n", s[i].grade);
                        printf("--------------------------------------\n");
                    }
                }

                break;

            case 3:
                printf("Thank you for using the Marksheet Generation System.\n");
                return 0;

            default:
                printf("Invalid choice! Please enter 1, 2 or 3.\n");
        }
    }

    return 0;
}