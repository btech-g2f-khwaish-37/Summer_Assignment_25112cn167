// Program to check whether a number is Perfect Number or not
#include <stdio.h>
int main()
{
    int num, i, sum = 0;

    printf("Enter a number: ");
    scanf("%d", &num);

    for(i = 1; i < num; i++)
    {
        if(num % i == 0)
        {
            sum = sum + i;
        }
    }
    if(sum == num)
        printf("%d is a Perfect Number.", num);
    else
        printf("%d is not a Perfect Number.", num);
    return 0;
}


// Program to check whether a number is Strong Number or not
#include <stdio.h>
int main()
{
    int num, temp, rem, i, fact, sum = 0;

    printf("Enter a number: ");
    scanf("%d", &num);

    temp = num;
    while(temp > 0)
    {
        rem = temp % 10;
        fact = 1;

        for(i = 1; i <= rem; i++)
        {
            fact = fact * i;
        }
        sum = sum + fact;
        temp = temp / 10;
    }
    if(sum == num)
        printf("%d is a Strong Number.", num);
    else
        printf("%d is not a Strong Number.", num);
    return 0;
}


// Program to print all factors of a number
#include <stdio.h>
int main()
{
    int num, i;

    printf("Enter a number: ");
    scanf("%d", &num);

    printf("Factors of %d are:\n", num);
    for(i = 1; i <= num; i++)
    {
        if(num % i == 0)
        {
            printf("%d ", i);
        }
    }
    return 0;
}


// program to Find Largest Prime Factor of a Number
#include <stdio.h>
int main()
{
    int num, i, largestPrimeFactor = -1;

    printf("Enter a number: ");
    scanf("%d", &num);

    if(num <= 1)
    {
        printf("No prime factors exist.\n");
        return 0;
    }
    // Find prime factors
    for(i = 2; i * i <= num; i++)
    {
        while(num % i == 0)
        {
            largestPrimeFactor = i;
            num = num / i;
        }
    }
    if(num > 1)
    {
        largestPrimeFactor = num;
    }

    printf("Largest Prime Factor = %d\n", largestPrimeFactor);

    return 0;
}