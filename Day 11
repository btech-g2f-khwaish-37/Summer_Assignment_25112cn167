// Program to Find Sum of Two Numbers Using a Function.

#include <stdio.h>

int findSum(int a, int b);

int main() {
    int num1, num2;

    printf("Enter two numbers: ");
    scanf("%d %d", &num1, &num2);

    printf("Sum = %d\n", findSum(num1, num2));

    return 0;
}

int findSum(int a, int b) {
    return a + b;
}


